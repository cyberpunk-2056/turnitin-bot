# ─── Twilio ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your Twilio WhatsApp sender (Sandbox: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Turnitin ─────────────────────────────────────────
TURNITIN_EMAIL=your@email.com
TURNITIN_PASSWORD=yourpassword
# Find these in your Turnitin URL: turnitin.com/...?account_id=XXX&class_id=YYY&assign_id=ZZZ
TURNITIN_ACCOUNT_ID=123456
TURNITIN_CLASS_ID=123456
TURNITIN_ASSIGN_ID=123456

# ─── Railway ──────────────────────────────────────────
# Your public Railway deployment URL (e.g. https://autoturnitin.up.railway.app)
PUBLIC_BASE_URL=https://your-app.up.railway.app

# Server port (Railway sets this automatically)
PORT=3000
